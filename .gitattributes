* text=auto

.gitattributes text eol=lf

# Keep consistent LF endings in repo (Windows-safe).
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Husky / shell scripts must remain LF.
.husky/* text eol=lf
*.sh text eol=lf

